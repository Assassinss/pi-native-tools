  },
  "optionalDependencies": {
    "@oh-my-pi/pi-natives-darwin-arm64": "latest",
    "@oh-my-pi/pi-natives-darwin-x64": "latest",
    "@oh-my-pi/pi-natives-linux-arm64": "latest",
    "@oh-my-pi/pi-natives-linux-x64": "latest",
    "@oh-my-pi/pi-natives-win32-x64": "latest"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
